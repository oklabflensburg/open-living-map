APP_NAME=Wohnort-Kompass API
ENV=development
API_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://wohnortkompass:wohnortkompass@localhost:5433/wohnortkompass
DEFAULT_SCORE_PERIOD=current
RAW_DATA_DIR=../../data/raw
STAGING_DATA_DIR=../../data/staging
GENESIS_API_KEY=
GENESIS_USERNAME=
GENESIS_PASSWORD=
GENESIS_API_URL=https://www.regionalstatistik.de/genesisws/rest/2020/data/table
GENESIS_CONNECT_TIMEOUT_SECONDS=30
GENESIS_READ_TIMEOUT_SECONDS=600
GENESIS_WRITE_TIMEOUT_SECONDS=60
GENESIS_POOL_TIMEOUT_SECONDS=60
GENESIS_REQUEST_RETRIES=3
GENESIS_LIMIT_COOLDOWN_SECONDS=0
# Optional: JSON Liste von Indikator-Spezifikationen fuer vollen Destatis-Import
# GENESIS_INDICATORS_JSON=[{"key":"population_total_destatis","name":"Bevoelkerung gesamt","category":"demographics","unit":"count","direction":"higher_is_better","table_code":"12411-0001"}]
GENESIS_INDICATORS_JSON=
UBA_API_BASE=https://www.umweltbundesamt.de/api/air-data/v4
DWD_BASE_URL=https://opendata.dwd.de/climate_environment/CDC/observations_germany/climate/daily/kl
DWD_MAX_STATIONS=0
DWD_RECENT_CACHE_MAX_AGE_HOURS=12
GEOFABRIK_GERMANY_PBF_URL=https://download.geofabrik.de/europe/germany-latest.osm.pbf
BKG_DISTRICT_TABLE=public.vg25_krs
BKG_MUNICIPALITY_TABLE=public.vg25_gem
BKG_GEOMETRY_COLUMN=geom
BKG_GEOMETRY_FLAVOUR=4
# Komma-separierte GTFS-Quellen:
# - HTTP(S)-Direktlinks auf GTFS-ZIP
# - oder lokale Dateien (/pfad/feed.zip oder file:///pfad/feed.zip)
OEPNV_GTFS_URLS=https://www.opendata-oepnv.de/fileadmin/datasets/delfi/20260413_fahrplaene_gesamtdeutschland_gtfs.zip
# Optional, falls GTFS-Ressourcen Basic Auth benoetigen
OEPNV_HTTP_USERNAME=
OEPNV_HTTP_PASSWORD=
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
WIKIPEDIA_LANGUAGE=de
